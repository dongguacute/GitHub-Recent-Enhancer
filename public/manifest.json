{
  "manifest_version": 3,
  "name": "GitHub Recent Enhancer",
  "version": "1.0.0",
  "description": "Restore the “Recent” feature on the GitHub web version (which was previously removed by GitHub for unknown reasons).",
  "permissions": ["storage", "sidePanel"],
  "icons": {
    "16": "logo-16.png",
    "32": "logo-32.png",
    "48": "logo-48.png",
    "128": "logo-128.png"
  },
  "action": {
    "default_title": "GitHub Recent Enhancer",
    "default_icon": {
      "16": "logo-16.png",
      "32": "logo-32.png",
      "48": "logo-48.png"
    }
  },
  "side_panel": {
    "default_path": "public/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
