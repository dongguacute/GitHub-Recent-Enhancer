{
  "manifest_version": 3,
  "name": "GitHub Recent Enhancer",
  "version": "1.0.0",
  "description": "Enhance GitHub recent activity experience",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
